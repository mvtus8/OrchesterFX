<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.orchesterfx.HelloController"
            style="-fx-background-color: #1e1e2e;">

    <!-- TOP: Toolbar s názvom a akciami skladu -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <Label text="🎼 Orchester FX" style="-fx-text-fill: #cdd6f4; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="💰 Cena Skladu"
                    style="-fx-background-color: #313244; -fx-text-fill: #a6e3a1; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18 8 18;"/>
            <Button text="▶ Sklad Hraj"
                    style="-fx-background-color: #313244; -fx-text-fill: #89dceb; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18 8 18;"/>
        </HBox>
    </top>

    <!-- CENTER: Tabuľka -->
    <center>
        <VBox spacing="0" style="-fx-background-color: #1e1e2e;">
            <padding><Insets top="20" right="24" bottom="0" left="24"/></padding>

            <Label text="Zoznam nástrojov"
                   style="-fx-text-fill: #cdd6f4; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <VBox.margin><Insets bottom="10"/></VBox.margin>

            <TableView fx:id="instrumentTableView" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="druhColumn"        text="Druh"        prefWidth="160"/>
                    <TableColumn fx:id="ksColumn"          text="Ks"          prefWidth="70"/>
                    <TableColumn fx:id="cenaColumn"        text="Cena (€)"    prefWidth="110"/>
                    <TableColumn fx:id="zvukColumn"        text="Zvuk"        prefWidth="120"/>
                    <TableColumn fx:id="pocetZvukovColumn" text="Počet zvukov" prefWidth="130"/>
                    <TableColumn fx:id="laDenieColumn"     text="Ladenie"     prefWidth="100"/>
                    <TableColumn fx:id="pocetDierColumn"   text="Počet dier"  prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <!-- BOTTOM: Editačný panel -->
    <bottom>
        <VBox style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>

            <Label text="Upraviť vybraný nástroj"
                   style="-fx-text-fill: #a6adc8; -fx-font-size: 13px;"/>
            <VBox.margin><Insets bottom="10"/></VBox.margin>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <!-- Vstupné polia -->
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Názov" style="-fx-text-fill: #6c7086; -fx-font-size: 11px;"/>
                    <TextField fx:id="inputNazov" promptText="Názov nástroja"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 13px; -fx-padding: 8 12 8 12;"
                               maxWidth="Infinity"/>
                </VBox>

                <VBox spacing="6" prefWidth="110">
                    <Label text="Počet (ks)" style="-fx-text-fill: #6c7086; -fx-font-size: 11px;"/>
                    <TextField fx:id="inputKs" promptText="0"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 13px; -fx-padding: 8 12 8 12;"/>
                </VBox>

                <VBox spacing="6" prefWidth="130">
                    <Label text="Cena (€)" style="-fx-text-fill: #6c7086; -fx-font-size: 11px;"/>
                    <TextField fx:id="inputCena" promptText="0.00"
                               style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-prompt-text-fill: #6c7086; -fx-border-color: #45475a; -fx-border-radius: 5; -fx-background-radius: 5; -fx-font-size: 13px; -fx-padding: 8 12 8 12;"/>
                </VBox>

                <!-- Akčné tlačidlá -->
                <VBox spacing="6" alignment="BOTTOM_LEFT">
                    <Label text="Akcie" style="-fx-text-fill: #6c7086; -fx-font-size: 11px;"/>
                    <HBox spacing="8">
                        <Button fx:id="addButton" text="➕ Pridať"
                                onAction="#onAddInstrument"
                                style="-fx-background-color: #a6e3a1; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18 8 18;"/>
                        <Button fx:id="updateButton" text="✏️ Upraviť"
                                onAction="#onUpdateInstrument"
                                style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18 8 18;"/>
                        <Button fx:id="deleteButton" text="🗑 Zmazať"
                                onAction="#onDeleteInstrument"
                                style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 8 18 8 18;"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>